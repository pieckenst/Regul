<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <TieredPGO>true</TieredPGO>
        <NoWarn>1701;1702;1705;1591;1573;CA1031;CA1822</NoWarn>
        <DisableImplicitNamespaceImports>true</DisableImplicitNamespaceImports>
        <Nullable>enable</Nullable>
        <LangVersion>preview</LangVersion>
        <AssemblyVersion>4.0.0</AssemblyVersion>
        <FileVersion>4.0.0</FileVersion>
        <ApplicationIcon>..\Regul.Assets\icon.ico</ApplicationIcon>
    </PropertyGroup>

    <!-- Enable console output in Debug builds -->
    <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
        <OutputType>Exe</OutputType>
    </PropertyGroup>

    <Import Project="..\..\build\Versions.props" />
    <Import Project="..\..\build\PlatformDependentCompilation.props" />

    <ItemGroup>
        <ProjectReference Include="..\Regul.Assets\Regul.Assets.csproj" />
        <ProjectReference Include="..\Regul.ModuleSystem\Regul.ModuleSystem.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Avalonia" Version="$(AvaloniaVersion)" />
        <PackageReference Include="Avalonia.Desktop" Version="$(AvaloniaVersion)" />
        <PackageReference Include="Avalonia.HarfBuzz" Version="$(AvaloniaVersion)" />
        <PackageReference Include="ReactiveUI.Avalonia" Version="11.4.12" />
        <PackageReference Include="PleasantUI" Version="5.2.2" />
        <PackageReference Include="PleasantUI.DataGrid" Version="5.2.2" />
        <PackageReference Include="PleasantUI.MaterialIcons" Version="5.2.2" />
        <PackageReference Include="PleasantUI.ToolKit" Version="5.2.2" />
        <PackageReference Include="VirusTotalNet" Version="2.1.0" />
    </ItemGroup>

    <ItemGroup>
        <None Remove=".gitignore" />
        <None Include="..\Regul.Assets\icon.ico">
            <Link>icon.ico</Link>
        </None>
    </ItemGroup>
</Project>
