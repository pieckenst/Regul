<PleasantWindow xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:Regul.CrashReport.ViewModels"
                mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="550"
                x:Class="Regul.CrashReport.Views.CrashReportWindow"
                x:DataType="vm:CrashReportViewModel"
                Icon="avares://Regul.Assets/icon.ico"
                Background="{DynamicResource BackgroundColor4}"
                Foreground="{DynamicResource TextFillColor1}"
                IsMinimizeButtonVisible="False"
                IsRestoreButtonVisible="False"
                Width="850"
                Height="550"
                CanResize="False"
                WindowStartupLocation="CenterScreen"
                Subtitle="{StaticResource CrashReport}"
                Title="Regul Crash Report">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header Section -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundColor3}"
                BorderBrush="{DynamicResource ControlBorderColor}"
                BorderThickness="0 0 0 1"
                Padding="30 25">
            <Grid ColumnDefinitions="Auto,*">
                <Panel Grid.Column="0"
                       Width="120"
                       Height="120"
                       Margin="0 0 30 0">
                    <Image Source="{StaticResource RegulIcon}"
                           Width="120"
                           Height="120" />
                    <Image Name="DangerImage"
                           Source="{StaticResource CriticalErrorImage}"
                           Width="60"
                           Height="60"
                           Margin="0 0 -10 -10"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Right" />
                </Panel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <TextBlock Theme="{DynamicResource TitleTextBlockTheme}"
                               Text="{StaticResource ThereWasAnException}"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{StaticResource ThereWasAnExceptionDescription}"
                               TextWrapping="Wrap"
                               Opacity="0.8"
                               FontSize="14"
                               LineHeight="20" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Section -->
        <Grid Grid.Row="1"
              Margin="30 25"
              RowDefinitions="Auto,*,Auto">
            <TextBlock Grid.Row="0"
                       Text="Детали ошибки:"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Margin="0 0 0 8"
                       Opacity="0.9" />
            
            <Border Grid.Row="1"
                    Background="{DynamicResource BackgroundColor2}"
                    BorderBrush="{DynamicResource ControlBorderColor}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0 0 8 8">
                    <TextBox Text="{CompiledBinding ExceptionText}"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="11"
                             Background="Transparent"
                             BorderThickness="0" />
                </ScrollViewer>
            </Border>

            <UniformGrid Grid.Row="2"
                         Rows="1"
                         Margin="0 15 0 0">
                <Button Content="{StaticResource Copy}"
                        Command="{CompiledBinding CopyLogs}"
                        CommandParameter="{CompiledBinding $self}"
                        Margin="0 0 8 0"
                        Height="36"
                        HorizontalContentAlignment="Center" />
                <Button Content="{StaticResource Save}"
                        Command="{CompiledBinding SaveLogs}"
                        CommandParameter="{CompiledBinding $parent[PleasantWindow]}"
                        Margin="8 0 0 0"
                        Height="36"
                        HorizontalContentAlignment="Center" />
            </UniformGrid>
        </Grid>

        <!-- Footer Section -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlBorderColor}"
                Background="{DynamicResource BackgroundColor3}"
                BorderThickness="0 1 0 0"
                Padding="30 20">
            <UniformGrid Rows="1"
                         HorizontalAlignment="Right"
                         Width="350">
                <Button Theme="{DynamicResource AccentButtonTheme}"
                        Content="{StaticResource Restart}"
                        Command="{CompiledBinding CloseAndRelaunch}"
                        CommandParameter="{CompiledBinding $parent[PleasantWindow]}"
                        Height="40"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Margin="0 0 10 0" />
                <Button Content="{StaticResource Close}"
                        Command="{CompiledBinding Close}"
                        CommandParameter="{CompiledBinding $parent[PleasantWindow]}"
                        Height="40"
                        FontSize="14"
                        Margin="10 0 0 0" />
            </UniformGrid>
        </Border>
    </Grid>
</PleasantWindow>